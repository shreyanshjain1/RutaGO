PORT=3000
GTFS_DIR=../../data/prepared
OTP_BASE_URL=http://localhost:8080
USE_POSTGRES=false
POSTGRES_REQUIRED=false
AUTO_IMPORT_GTFS_TO_DB=false
DATABASE_URL=postgresql://postgres:password@localhost:5432/rutago
OTP_TRANSIT_PREFERRED=true
OTP_ALLOW_WALK_FALLBACK=true
OTP_MAX_WALK_METERS=1500

# Local auth/session signing. Change this before any real deployment.
SESSION_SECRET=change-me-to-a-long-random-secret

# Comma-separated emails that should receive admin access after signup/login.
# Example: ADMIN_EMAILS=owner@example.com,developer@example.com
ADMIN_EMAILS=
